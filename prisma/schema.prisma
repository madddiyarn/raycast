generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  passwordHash  String
  name          String?
  emailVerified DateTime?
  role          String    @default("candidate")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  telegram      String?
  profile       CandidateProfile?
  applications  Application[]
}

model CandidateProfile {
  id               String   @id @default(cuid())
  userId           String   @unique
  user             User     @relation(fields: [userId], references: [id])
  district         String?
  category         String?
  skills           String?
  experience       String?
  availability     String?  @default("immediately")
  studentStatus    Boolean  @default(false)
  preferredSalary  Int?
  updatedAt        DateTime @updatedAt
}

model Application {
  id        String   @id @default(cuid())
  jobId     String
  job       Job      @relation(fields: [jobId], references: [id])
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  status    String   @default("pending") // pending, interview, rejected, accepted
  matchScore Int?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Job {
  id                 String   @id @default(cuid())
  rawText            String
  title              String
  description        String
  category           String
  district           String
  salaryMin          Int
  salaryMax          Int
  salaryText         String
  schedule           String
  employmentType     String
  experienceRequired Boolean  @default(false)
  studentFriendly    Boolean  @default(false)
  contact            String
  sourceType         String   @default("telegram")
  status             String   @default("published")
  employerId         String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  applications       Application[]
}

model TelegramSession {
  id          String   @id @default(cuid())
  chatId      String   @unique
  state       String   @default("IDLE")
  data        Json?    // Stores parsed vacancy data, missing fields, etc.
  lastMessage DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
