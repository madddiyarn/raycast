generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  passwordHash  String
  name          String?
  emailVerified DateTime?
  role          String    @default("candidate")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  telegram      String?
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Job {
  id                 String   @id @default(cuid())
  rawText            String
  title              String
  description        String
  category           String
  district           String
  salaryMin          Int
  salaryMax          Int
  salaryText         String
  schedule           String
  employmentType     String
  experienceRequired Boolean  @default(false)
  studentFriendly    Boolean  @default(false)
  contact            String
  sourceType         String   @default("telegram")
  status             String   @default("published")
  employerId         String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}
